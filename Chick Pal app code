// MqttService.ts — HiveMQ public broker over WebSockets for ChickPal coop
import mqtt, { type MqttClient } from "mqtt";

export const MQTT_BROKER_URL = "wss://broker.hivemq.com:8884/mqtt";
export const TOPIC_CMD = "coop/device/cmd";
export const TOPIC_TELEMETRY = "coop/app/telemetry";
export const TOPIC_ALERTS = "coop/app/alerts";

export type CoopCommand = "FEED_NOW" | "WARM_CHICKS" | "NOT_AROUND" | "WASTE_DISPOSED";

export interface CoopTelemetry {
  temperature?: number;
  humidity?: number;
  water_level?: number;
  lights_on?: boolean;
  waste_pending?: boolean;
}
export interface CoopAlert { alert_type: string; message: string; }

let client: MqttClient | null = null;

export function getMqttClient(): MqttClient {
  if (client) return client;
  const clientId = `chickpal_${Math.random().toString(16).slice(2, 10)}`;
  client = mqtt.connect(MQTT_BROKER_URL, {
    clientId, clean: true, reconnectPeriod: 3000, connectTimeout: 8000,
  });
  return client;
}

export function publishCommand(command: CoopCommand, extra: Record<string, unknown> = {}) {
  const c = getMqttClient();
  const payload = JSON.stringify({ command, ...extra });
  c.publish(TOPIC_CMD, payload, { qos: 0 }, (err) => {
    if (err) console.error("MQTT publish failed:", err);
    else console.log("MQTT →", TOPIC_CMD, payload);
  });
}
